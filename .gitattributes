# Auto detect text files and perform LF normalization
* text=auto

# SQL files
*.sql text eol=lf

# JavaScript/JSX
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# JSON
*.json text eol=lf

# CSS
*.css text eol=lf

# HTML
*.html text eol=lf

# Markdown
*.md text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
