<svg xmlns="http://www.w3.org/2000/svg" width="300" height="360" viewBox="0 0 300 360" fill="none">
  <defs>
    <linearGradient id="shadow" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#000" stop-opacity="0.15" />
      <stop offset="1" stop-color="#000" stop-opacity="0" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="300" height="360" fill="#FEF9F3" rx="30" />
  
  <!-- Shadow at bottom -->
  <ellipse cx="150" cy="320" rx="80" ry="20" fill="url(#shadow)" />
  
  <!-- Cake base (cream) -->
  <rect x="60" y="180" width="180" height="20" rx="10" fill="#F4D5A0" />
  
  <!-- Cake layer 1 (sponge) -->
  <rect x="50" y="150" width="200" height="35" rx="8" fill="#E8C774" />
  
  <!-- Cake layer 2 (cream) -->
  <rect x="60" y="130" width="180" height="20" rx="10" fill="#F4D5A0" />
  
  <!-- Cake layer 3 (sponge) -->
  <rect x="50" y="100" width="200" height="35" rx="8" fill="#D4B86A" />
  
  <!-- Top cream layer -->
  <ellipse cx="150" cy="105" rx="110" ry="30" fill="#F4D5A0" />
  
  <!-- Cake top -->
  <path d="M 60 100 Q 150 40 240 100 L 240 120 Q 150 80 60 120 Z" fill="#D4B86A" />
  
  <!-- Strawberry on top -->
  <g transform="translate(150, 50)">
    <!-- Strawberry body -->
    <ellipse cx="0" cy="8" rx="15" ry="18" fill="#E63946" />
    <!-- Strawberry leaves -->
    <g transform="translate(0, -12)">
      <ellipse cx="-8" cy="0" rx="4" ry="8" fill="#2D6A4F" transform="rotate(-30)" />
      <ellipse cx="0" cy="-2" rx="4" ry="9" fill="#2D6A4F" />
      <ellipse cx="8" cy="0" rx="4" ry="8" fill="#2D6A4F" transform="rotate(30)" />
    </g>
    <!-- Seeds -->
    <circle cx="-6" cy="6" r="1.5" fill="#FFD166" />
    <circle cx="-2" cy="2" r="1.5" fill="#FFD166" />
    <circle cx="2" cy="10" r="1.5" fill="#FFD166" />
    <circle cx="6" cy="5" r="1.5" fill="#FFD166" />
    <circle cx="0" cy="14" r="1.5" fill="#FFD166" />
  </g>
</svg>
